<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/documentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/documents_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/documentScanSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/documents_scan_toggle" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/documentAutoSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/documents_auto_capture" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/documentSpeakSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/documents_speak_result" />

        <TextView
            android:id="@+id/documentStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/documents_status_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/documentStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityLiveRegion="polite"
            android:text="@string/documents_status_idle" />

        <TextView
            android:id="@+id/documentResultLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/documents_result_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/documentResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="" />

    </LinearLayout>
</ScrollView>
