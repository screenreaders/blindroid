<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/obstacleTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/obstacle_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/obstacleActiveSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/obstacle_active" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/obstacleSoundSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/obstacle_sound" />

        <TextView
            android:id="@+id/obstacleStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/obstacle_status_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/obstacleStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/obstacle_status_idle" />
    </LinearLayout>
</ScrollView>
