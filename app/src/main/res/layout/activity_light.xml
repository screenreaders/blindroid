<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/lightTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/light_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/lightActiveSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/light_active_toggle" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/lightDirectionSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/light_direction_toggle" />

        <TextView
            android:id="@+id/lightLuxLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/light_lux_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lightLuxValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/light_lux_initial" />

        <TextView
            android:id="@+id/lightDirectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/light_direction_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lightDirectionValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityLiveRegion="polite"
            android:text="@string/light_direction_idle" />

        <TextView
            android:id="@+id/lightHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/light_hint" />

    </LinearLayout>
</ScrollView>
