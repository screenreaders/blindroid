<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/talkbackTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/talkback_wizard_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/talkbackSystemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/talkback_system_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/talkbackStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_status_off" />

        <TextView
            android:id="@+id/talkbackHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_hint" />

        <TextView
            android:id="@+id/talkbackGestureSetHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/talkback_gesture_set_hint" />

        <Button
            android:id="@+id/talkbackSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_open_settings" />

        <Button
            android:id="@+id/talkbackShortcutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/talkback_open_shortcut" />

        <TextView
            android:id="@+id/backupTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/talkback_backup_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/backupStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_backup_status_off" />

        <TextView
            android:id="@+id/backupHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_backup_hint" />

        <Button
            android:id="@+id/backupSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/talkback_backup_open_settings" />

        <Button
            android:id="@+id/talkbackRefreshButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/talkback_refresh" />
    </LinearLayout>
</ScrollView>
