<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/brailleStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/braille_status_letters"
        android:textStyle="bold"
        android:textSize="18sp" />

    <GridLayout
        android:id="@+id/brailleDots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:columnCount="2"
        android:rowCount="3">

        <ToggleButton
            android:id="@+id/brailleDot1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="1"
            android:textOn="1"
            android:textSize="20sp" />

        <ToggleButton
            android:id="@+id/brailleDot4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="4"
            android:textOn="4"
            android:textSize="20sp" />

        <ToggleButton
            android:id="@+id/brailleDot2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="2"
            android:textOn="2"
            android:textSize="20sp" />

        <ToggleButton
            android:id="@+id/brailleDot5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="5"
            android:textOn="5"
            android:textSize="20sp" />

        <ToggleButton
            android:id="@+id/brailleDot3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="3"
            android:textOn="3"
            android:textSize="20sp" />

        <ToggleButton
            android:id="@+id/brailleDot6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:textOff="6"
            android:textOn="6"
            android:textSize="20sp" />
    </GridLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/brailleWrite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/braille_write" />

        <Button
            android:id="@+id/brailleSpace"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/braille_space" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/brailleBackspace"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/braille_backspace" />

        <Button
            android:id="@+id/brailleEnter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/braille_enter" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/brailleClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/braille_clear" />

        <Button
            android:id="@+id/brailleCaps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/braille_caps" />

        <Button
            android:id="@+id/brailleNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/braille_numbers" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/braillePolishScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/braillePolishRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>
</LinearLayout>
