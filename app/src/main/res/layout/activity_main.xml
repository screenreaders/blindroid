<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/roleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/role_button_request" />

        <TextView
            android:id="@+id/launcherLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/launcher_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/launcherSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_enable" />

        <TextView
            android:id="@+id/launcherHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_hint" />

        <Button
            android:id="@+id/launcherSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_settings" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/moduleShortcutsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/module_shortcuts" />

        <TextView
            android:id="@+id/simplePhoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/simple_section_label"
            android:textStyle="bold" />

        <Button
            android:id="@+id/contactTilesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/contact_tiles_open" />

        <Button
            android:id="@+id/simplePhoneButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/simple_phone_open" />

        <Button
            android:id="@+id/simpleMessagesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/simple_messages_open" />

        <Button
            android:id="@+id/brailleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/braille_open" />

        <TextView
            android:id="@+id/callsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_calls"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/numberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/phone_number_hint"
            android:inputType="phone" />

        <Button
            android:id="@+id/callButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/call_button" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/announceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/switch_announce" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/speakerSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_speaker" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callWaitingSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_waiting" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callStateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_state" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callVibrateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_vibrate" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/endCallVibrateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_end_call_vibrate" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/voiceCommandsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_voice_commands" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/missedCallBackSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/missed_call_back_enable" />

        <TextView
            android:id="@+id/backTapSensitivityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/backTapSensitivitySpinner"
            android:text="@string/back_tap_sensitivity"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/backTapSensitivitySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/endCallKeyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/endCallKeySpinner"
            android:text="@string/end_call_key"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/endCallKeySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/endCallPowerHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/end_call_power_hint"
            android:visibility="gone" />

        <Button
            android:id="@+id/accessibilitySettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/open_accessibility_settings"
            android:visibility="gone" />

        <TextView
            android:id="@+id/lowVisionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/low_vision_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/lowVisionSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/low_vision_enable" />

        <TextView
            android:id="@+id/lowVisionPresetLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/low_vision_preset_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/lowVisionPresetSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/lowVisionThemeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/low_vision_theme"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/lowVisionThemeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/lowVisionInvertSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/low_vision_invert" />

        <TextView
            android:id="@+id/lowVisionScaleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/low_vision_scale"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lowVisionScaleValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%" />

        <SeekBar
            android:id="@+id/lowVisionScaleSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="150"
            android:min="100" />

        <TextView
            android:id="@+id/ttsModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/tts_mode"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/ttsModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/ttsModeRingSpeech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_ring_and_speech" />

            <RadioButton
                android:id="@+id/ttsModeSpeechOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_speech_only" />

            <RadioButton
                android:id="@+id/ttsModeSpeechThenRing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_speech_then_ring" />
        </RadioGroup>

        <TextView
            android:id="@+id/ttsVoiceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsVoiceSpinner"
            android:text="@string/tts_voice"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/ttsVoiceSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/ttsRateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsRateSeek"
            android:text="@string/tts_rate"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsRateValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x" />

        <SeekBar
            android:id="@+id/ttsRateSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:min="50" />

        <TextView
            android:id="@+id/ttsVolumeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsVolumeSeek"
            android:text="@string/tts_volume"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%" />

        <SeekBar
            android:id="@+id/ttsVolumeSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/ttsRepeatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsRepeatSeek"
            android:text="@string/tts_repeat"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsRepeatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x" />

        <SeekBar
            android:id="@+id/ttsRepeatSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:min="1" />

        <Button
            android:id="@+id/contactsPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/permission_contacts" />

        <TextView
            android:id="@+id/notificationsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_notifications"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/smsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_sms" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/notificationSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_notifications" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/unlockedSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_unlocked" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/privacySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_privacy" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/privacyTitleSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_privacy_title" />

        <Button
            android:id="@+id/notificationAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/notification_access_button" />

        <TextView
            android:id="@+id/nightLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_night"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nightSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_enable" />

        <TextView
            android:id="@+id/nightStartLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_start"
            android:textStyle="bold" />

        <Button
            android:id="@+id/nightStartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="22:00" />

        <TextView
            android:id="@+id/nightEndLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_end"
            android:textStyle="bold" />

        <Button
            android:id="@+id/nightEndButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="07:00" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nightMuteCallsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_mute_calls" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nightMuteSmsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_mute_sms" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nightMuteNotificationsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_mute_notifications" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nightMuteChimeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/night_mute_chime" />

        <TextView
            android:id="@+id/accessibilityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_accessibility"
            android:textStyle="bold" />

        <Button
            android:id="@+id/talkbackWizardButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/talkback_wizard" />

        <TextView
            android:id="@+id/cameraLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_camera"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/documentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_documents"
            android:textStyle="bold" />

        <Button
            android:id="@+id/documentsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/documents_open" />

        <TextView
            android:id="@+id/faceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_face"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/faceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/face_enable" />

        <Button
            android:id="@+id/faceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/face_open" />

        <TextView
            android:id="@+id/faceHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/face_hint" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/facePickupSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/face_pickup_enable" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/answerPickupSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/answer_pickup_enable" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/faceShortcutSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/face_shortcut_enable" />

        <TextView
            android:id="@+id/obstacleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_obstacle"
            android:textStyle="bold" />

        <Button
            android:id="@+id/obstacleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/obstacle_open" />

        <TextView
            android:id="@+id/currencyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_currency"
            android:textStyle="bold" />

        <Button
            android:id="@+id/currencyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/currency_open" />

        <TextView
            android:id="@+id/currencyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/currency_hint" />

        <TextView
            android:id="@+id/lightLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_light"
            android:textStyle="bold" />

        <Button
            android:id="@+id/lightButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/light_open" />

        <TextView
            android:id="@+id/lightHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/light_hint" />

        <TextView
            android:id="@+id/navigationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/navigation_label"
            android:textStyle="bold" />

        <Button
            android:id="@+id/navigationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_open" />

        <TextView
            android:id="@+id/safetyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_safety"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sosLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sos_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/sosNumberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/sos_number"
            android:inputType="phone" />

        <EditText
            android:id="@+id/sosMessageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/sos_message"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/sosCallButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sos_call" />

        <Button
            android:id="@+id/sosSmsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sos_sms" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sosShakeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sos_shake" />

        <TextView
            android:id="@+id/sosShakeSensitivityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/sosShakeSensitivitySpinner"
            android:text="@string/shake_sensitivity"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/sosShakeSensitivitySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/chimeLabel"
