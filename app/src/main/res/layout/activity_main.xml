<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/roleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/role_button_request" />

        <TextView
            android:id="@+id/launcherLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/launcher_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/launcherSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_enable" />

        <TextView
            android:id="@+id/launcherHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_hint" />

        <Button
            android:id="@+id/launcherSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_settings" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/moduleShortcutsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/module_shortcuts" />

        <TextView
            android:id="@+id/callsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_calls"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/numberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/phone_number_hint"
            android:inputType="phone" />

        <Button
            android:id="@+id/callButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/call_button" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/announceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/switch_announce" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/speakerSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_speaker" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callWaitingSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_waiting" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callStateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_state" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/callVibrateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_call_vibrate" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/endCallVibrateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_end_call_vibrate" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/voiceCommandsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_voice_commands" />

        <TextView
            android:id="@+id/endCallKeyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/endCallKeySpinner"
            android:text="@string/end_call_key"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/endCallKeySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/endCallPowerHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/end_call_power_hint"
            android:visibility="gone" />

        <Button
            android:id="@+id/accessibilitySettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/open_accessibility_settings"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ttsModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/tts_mode"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/ttsModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/ttsModeRingSpeech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_ring_and_speech" />

            <RadioButton
                android:id="@+id/ttsModeSpeechOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_speech_only" />

            <RadioButton
                android:id="@+id/ttsModeSpeechThenRing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_mode_speech_then_ring" />
        </RadioGroup>

        <TextView
            android:id="@+id/ttsVoiceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsVoiceSpinner"
            android:text="@string/tts_voice"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/ttsVoiceSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/ttsRateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsRateSeek"
            android:text="@string/tts_rate"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsRateValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x" />

        <SeekBar
            android:id="@+id/ttsRateSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:min="50" />

        <TextView
            android:id="@+id/ttsVolumeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsVolumeSeek"
            android:text="@string/tts_volume"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%" />

        <SeekBar
            android:id="@+id/ttsVolumeSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/ttsRepeatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:labelFor="@id/ttsRepeatSeek"
            android:text="@string/tts_repeat"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ttsRepeatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x" />

        <SeekBar
            android:id="@+id/ttsRepeatSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:min="1" />

        <Button
            android:id="@+id/contactsPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/permission_contacts" />

        <TextView
            android:id="@+id/notificationsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_notifications"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/smsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_sms" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/notificationSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_notifications" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/unlockedSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_unlocked" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/privacySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_privacy" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/privacyTitleSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/switch_privacy_title" />

        <Button
            android:id="@+id/notificationAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/notification_access_button" />

        <TextView
            android:id="@+id/cameraLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_camera"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/currencyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_currency"
            android:textStyle="bold" />

        <Button
            android:id="@+id/currencyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/currency_open" />

        <TextView
            android:id="@+id/currencyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/currency_hint" />

        <TextView
            android:id="@+id/lightLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/section_light"
            android:textStyle="bold" />

        <Button
            android:id="@+id/lightButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/light_open" />

        <TextView
            android:id="@+id/lightHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/light_hint" />

        <TextView
            android:id="@+id/chimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/chime_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/chimeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/chime_enable" />

        <TextView
            android:id="@+id/chimeIntervalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/chimeIntervalSpinner"
            android:text="@string/chime_interval"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/chimeIntervalSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/chimeStartLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/chimeStartButton"
            android:text="@string/chime_start"
            android:textStyle="bold" />

        <Button
            android:id="@+id/chimeStartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="06:00" />

        <TextView
            android:id="@+id/chimeEndLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/chimeEndButton"
            android:text="@string/chime_end"
            android:textStyle="bold" />

        <Button
            android:id="@+id/chimeEndButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00" />

        <TextView
            android:id="@+id/updateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/update_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/updateAutoSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/update_auto" />

        <TextView
            android:id="@+id/updateStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:accessibilityLiveRegion="polite"
            android:text="@string/update_status_idle" />

        <Button
            android:id="@+id/updateCheckButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/update_check_now" />

    </LinearLayout>
</ScrollView>
