<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/navigationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/navigation_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/navigationPlaceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/navigation_place_hint"
            android:inputType="textPostalAddress" />

        <EditText
            android:id="@+id/navigationCityInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/navigation_city_hint"
            android:inputType="text" />

        <RadioGroup
            android:id="@+id/navigationModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/navigationModeDriving"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_mode_driving" />

            <RadioButton
                android:id="@+id/navigationModeWalking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_mode_walking" />

            <RadioButton
                android:id="@+id/navigationModeBicycling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_mode_bicycling" />

            <RadioButton
                android:id="@+id/navigationModeTransit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_mode_transit" />
        </RadioGroup>

        <Button
            android:id="@+id/navigationStartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/navigation_start" />

        <TextView
            android:id="@+id/navigationTrackingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/navigation_tracking_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/navigationTrackingSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_tracking_enable" />

        <TextView
            android:id="@+id/navigationPoiSourceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/navigation_poi_source_label"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/navigationPoiSourceGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/navigationPoiSourceGoogle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_poi_source_google" />

            <RadioButton
                android:id="@+id/navigationPoiSourceOffline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_poi_source_offline" />

            <RadioButton
                android:id="@+id/navigationPoiSourceOsm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_poi_source_osm" />

            <RadioButton
                android:id="@+id/navigationPoiSourceHybrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_poi_source_hybrid" />
        </RadioGroup>

        <Button
            android:id="@+id/navigationOfflineImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_offline_import" />

        <Button
            android:id="@+id/navigationOfflineClearButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/navigation_offline_clear" />

        <TextView
            android:id="@+id/navigationOfflineStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/navigation_offline_empty" />

        <EditText
            android:id="@+id/navigationOfflineBaseUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/navigation_offline_base_url_hint"
            android:inputType="textUri" />

        <Button
            android:id="@+id/navigationOfflineCheckButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/navigation_offline_check" />

        <TextView
            android:id="@+id/navigationOfflineBaseUrlHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/navigation_offline_base_url_info" />

        <TextView
            android:id="@+id/navigationOfflineZoomLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_offline_zoom_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/navigationOfflineZoomSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/navigationImportRadiusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_import_radius_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/navigationImportRadiusSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/navigationImportModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_import_mode_label"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/navigationImportModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/navigationImportModeRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_import_mode_radius" />

            <RadioButton
                android:id="@+id/navigationImportModeManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation_import_mode_manual" />
        </RadioGroup>

        <TextView
            android:id="@+id/navigationImportManualHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/navigation_import_manual_hint"
            android:visibility="gone" />

        <EditText
            android:id="@+id/navigationImportMinLatInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/navigation_import_min_lat"
            android:inputType="numberDecimal|numberSigned"
            android:visibility="gone" />

        <EditText
            android:id="@+id/navigationImportMinLonInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/navigation_import_min_lon"
            android:inputType="numberDecimal|numberSigned"
            android:visibility="gone" />

        <EditText
            android:id="@+id/navigationImportMaxLatInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/navigation_import_max_lat"
            android:inputType="numberDecimal|numberSigned"
            android:visibility="gone" />

        <EditText
            android:id="@+id/navigationImportMaxLonInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/navigation_import_max_lon"
            android:inputType="numberDecimal|numberSigned"
            android:visibility="gone" />

        <TextView
            android:id="@+id/navigationRadiusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/navigationRadiusSpinner"
            android:text="@string/navigation_radius_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/navigationRadiusSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/navigationIntervalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/navigationIntervalSpinner"
            android:text="@string/navigation_interval_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/navigationIntervalSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/navigationMinDistanceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:labelFor="@id/navigationMinDistanceSpinner"
            android:text="@string/navigation_min_distance_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/navigationMinDistanceSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/navigationMovingOnlySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_moving_only" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/navigationTrackLogSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_track_log" />

        <Button
            android:id="@+id/navigationShareTrackButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_share_track" />

        <Button
            android:id="@+id/navigationShareGpxButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_share_gpx" />

        <Button
            android:id="@+id/navigationSharePinButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_share_pin" />

        <Button
            android:id="@+id/navigationCategoriesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_categories_button" />

        <TextView
            android:id="@+id/navigationCategoriesSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/navigation_categories_none" />

        <EditText
            android:id="@+id/navigationApiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/navigation_api_key_hint"
            android:inputType="textPassword" />

        <TextView
            android:id="@+id/navigationApiKeyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/navigation_api_key_info" />

        <TextView
            android:id="@+id/navigationHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/navigation_hint" />

        <TextView
            android:id="@+id/navigationTyflomapLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/tyflomap_label"
            android:textStyle="bold" />

        <Button
            android:id="@+id/navigationTyflomapCheckButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tyflomap_check" />

        <TextView
            android:id="@+id/navigationTyflomapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tyflomap_status_idle" />

        <Button
            android:id="@+id/navigationTyflomapOpenButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tyflomap_open_link" />

        <Button
            android:id="@+id/navigationTyflomapShareButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tyflomap_share_link" />
    </LinearLayout>
</ScrollView>
