<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <application>
        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:enabled="false"
            android:label="@string/launcher_name"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AllAppsActivity"
            android:exported="false"
            android:label="@string/launcher_all_apps"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".FolderActivity"
            android:exported="false"
            android:label="@string/launcher_folder_title"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".WidgetsActivity"
            android:exported="false"
            android:label="@string/launcher_widgets_title"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".LauncherSettingsActivity"
            android:exported="false"
            android:label="@string/launcher_settings_title"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <receiver
            android:name=".LauncherAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/launcher_device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
