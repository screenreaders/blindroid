<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_feed" />

        <Switch
            android:id="@+id/feedEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_feed_enabled" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_settings_feed_mode" />

        <Spinner
            android:id="@+id/feedModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_grid" />

        <RadioGroup
            android:id="@+id/columnsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/columns4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_columns_4" />

            <RadioButton
                android:id="@+id/columns5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_columns_5" />
        </RadioGroup>

        <RadioGroup
            android:id="@+id/rowsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rows4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_rows_4" />

            <RadioButton
                android:id="@+id/rows5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_rows_5" />

            <RadioButton
                android:id="@+id/rows6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_rows_6" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_icon_size" />

        <RadioGroup
            android:id="@+id/iconSizeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/iconSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_small" />

            <RadioButton
                android:id="@+id/iconNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_normal" />

            <RadioButton
                android:id="@+id/iconLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_large" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_label_size" />

        <RadioGroup
            android:id="@+id/labelSizeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/labelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_small" />

            <RadioButton
                android:id="@+id/labelNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_normal" />

            <RadioButton
                android:id="@+id/labelLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_large" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_dock" />

        <Switch
            android:id="@+id/dockVisibleSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_dock_visible" />

        <Switch
            android:id="@+id/hideDockLabelsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_hide_dock_labels" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_modes" />

        <Switch
            android:id="@+id/superSimpleSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_super_simple" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_theme" />

        <RadioGroup
            android:id="@+id/themeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/themeLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_theme_light" />

            <RadioButton
                android:id="@+id/themeDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_theme_dark" />

            <RadioButton
                android:id="@+id/themeBlack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_theme_black" />

            <RadioButton
                android:id="@+id/themeBlue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_theme_blue" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_icon_style" />

        <RadioGroup
            android:id="@+id/iconStyleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/iconStyleNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_settings_icon_style_none" />

            <RadioButton
                android:id="@+id/iconStyleCircle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/launcher_settings_icon_style_circle" />
        </RadioGroup>

        <Button
            android:id="@+id/wallpaperButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/launcher_settings_wallpaper" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/launcher_settings_gestures" />

        <Switch
            android:id="@+id/doubleTapLockSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_settings_double_tap_lock" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/launcher_gesture_two_tap" />

        <Spinner
            android:id="@+id/gestureTwoTapSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_two_up" />

        <Spinner
            android:id="@+id/gestureTwoUpSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_two_down" />

        <Spinner
            android:id="@+id/gestureTwoDownSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_two_left" />

        <Spinner
            android:id="@+id/gestureTwoLeftSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_two_right" />

        <Spinner
            android:id="@+id/gestureTwoRightSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/launcher_gesture_three_tap" />

        <Spinner
            android:id="@+id/gestureThreeTapSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_three_up" />

        <Spinner
            android:id="@+id/gestureThreeUpSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_three_down" />

        <Spinner
            android:id="@+id/gestureThreeDownSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_three_left" />

        <Spinner
            android:id="@+id/gestureThreeLeftSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/launcher_gesture_three_right" />

        <Spinner
            android:id="@+id/gestureThreeRightSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/closeSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/launcher_settings_close" />

    </LinearLayout>
</ScrollView>
