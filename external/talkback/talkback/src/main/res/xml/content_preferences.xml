<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

  <com.google.android.accessibility.utils.preference.AccessibilitySuiteSwitchPreference
      android:defaultValue="@bool/pref_read_all_auto_ocr_default"
      android:key="@string/pref_read_all_auto_ocr_key"
      android:title="@string/pref_read_all_auto_ocr_title"
      android:summary="@string/pref_read_all_auto_ocr_summary" />

  <ListPreference
      android:defaultValue="@string/pref_read_all_filter_default"
      android:key="@string/pref_read_all_filter_key"
      android:title="@string/pref_read_all_filter_title"
      android:summary="@string/pref_read_all_filter_summary"
      android:entries="@array/pref_read_all_filter_entries"
      android:entryValues="@array/pref_read_all_filter_values" />

  <ListPreference
      android:defaultValue="@string/pref_read_all_style_default"
      android:key="@string/pref_read_all_style_key"
      android:title="@string/pref_read_all_style_title"
      android:summary="@string/pref_read_all_style_summary"
      android:entries="@array/pref_read_all_style_entries"
      android:entryValues="@array/pref_read_all_style_values" />

</PreferenceScreen>
