<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

  <com.google.android.accessibility.utils.preference.AccessibilitySuiteSwitchPreference
      android:defaultValue="@bool/pref_macro_enabled_default"
      android:key="@string/pref_macro_enabled_key"
      android:title="@string/pref_macro_enabled_title"
      android:summary="@string/pref_macro_enabled_summary" />

  <PreferenceCategory
      android:title="@string/pref_macro_category_1">
    <EditTextPreference
        android:key="@string/pref_macro_1_name_key"
        android:title="@string/pref_macro_name_title"
        android:defaultValue="@string/macro_default_name_1" />
    <Preference
        android:key="@string/pref_macro_1_actions_list_key"
        android:title="@string/pref_macro_actions_title" />
  </PreferenceCategory>

  <PreferenceCategory
      android:title="@string/pref_macro_category_2">
    <EditTextPreference
        android:key="@string/pref_macro_2_name_key"
        android:title="@string/pref_macro_name_title"
        android:defaultValue="@string/macro_default_name_2" />
    <Preference
        android:key="@string/pref_macro_2_actions_list_key"
        android:title="@string/pref_macro_actions_title" />
  </PreferenceCategory>

  <PreferenceCategory
      android:title="@string/pref_macro_category_3">
    <EditTextPreference
        android:key="@string/pref_macro_3_name_key"
        android:title="@string/pref_macro_name_title"
        android:defaultValue="@string/macro_default_name_3" />
    <Preference
        android:key="@string/pref_macro_3_actions_list_key"
        android:title="@string/pref_macro_actions_title" />
  </PreferenceCategory>

  <Preference
      android:key="@string/pref_macro_export_key"
      android:title="@string/pref_macro_export_title"
      android:summary="@string/pref_macro_export_summary" />

  <Preference
      android:key="@string/pref_macro_import_key"
      android:title="@string/pref_macro_import_title"
      android:summary="@string/pref_macro_import_summary" />

  <Preference
      android:key="@string/pref_macro_export_file_key"
      android:title="@string/pref_macro_export_file_title"
      android:summary="@string/pref_macro_export_file_summary" />

  <Preference
      android:key="@string/pref_macro_import_file_key"
      android:title="@string/pref_macro_import_file_title"
      android:summary="@string/pref_macro_import_file_summary" />
</PreferenceScreen>
