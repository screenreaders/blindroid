[ć|č|{cz}]:ч|
{ch}:х|
d:д|
[{dž}|{dż}]:{дж}|
[dź]:{дзь}|
e:э|
f:ф|
g:г|
h:х|
i:і|
j:й|
[{ja}|{ya}]:я|
[{je}|{ye}]:е|
[{jo}|{io}]:ё|
[{ju}|{yu}]:ю|
[k|q]:к|
l:л|
ł:л|
m:м|
n:н|
ń:{нь}|
o:о|
ó:у|
p:п|
r:р|
{rz}:ж|
s:с|
ś:{шч}|
{sh}:ш|
{sz}:ш|
{szcz}:{шч}|
t:т|
u:у|
