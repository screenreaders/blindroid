define NZDigit 
1 : адзІн | 
2 : двА | 
3 : трЫ | 
4 : чатЫры | 
5 : пЯць | 
6 : шЭсць | 
7 : сЕм | 
8 : вОсем | 
9 : дзЕвяць ;

define Digit [%0 : нУль] | NZDigit;

define Number 
NZDigit | 
[[1:0] [
%0:дзЕсяць | 
1:адзінАццаць | 
2:дванАццаць | 
3:трынАццаць | 
4:чатырнАццаць | 
5:пятнАццаць | 
6:шаснАццаць | 
7:сямнАццаць | 
8:васямнАццаць | 
9:дзевятнАццаць]] | 
[[2:двАццаць] [%0:0 | NZDigit]] ;

define Plus %+ : плюс;
define Minus %- : мінус;
define Slash %/ : касая рыска;
define BackSlash %\ : адваротна касая рыска;
define Star %* : зорачка;
define Dot %. : кропка;
define SpecialChar Plus | Minus | Slash | BackSlash | Star | Dot;

define Enter {enter} : энтэр;

define OtherKey 
{underscore} : падкрэсліванне | 
{double-quote} : двухкоссе | 
{alt} : альт | 
{control} : контроль | 
{hyper} : гипер | 
{meta} : мэта | 
{shift} : шифт | 
{super} : супэр | 
{backspace} : [бэк спэйс] | 
{break} : брэйк | 
{delete} : дзилит | 
{down} : ў низ | 
{end} : энд | 
Эntэr | 
{escape} : эскэйп | 
{home} : хоум | 
{insert} : инсэрт | 
{left} : ў лева | 
{menu} : меню | 
{next} : наступная | 
{num-lock} : [нам лок] | 
{pause} : пауза | 
{print} : печать | 
{prior} : папярэдняя | 
{return} : перавод радка | 
{right} : на права | 
{scroll-lock} : [скрол лок] | 
{space} : прабел | 
{tab} : таб | 
{up} : верх | 
{window} : виндоуз ; 

define KPKey 
[{kp-} : 0] [Digit | Plus | Minus | Star | Slash | Dot | Enter];

define FKey 
f:эф Number ;

define Key 
KPKey | FKey | SpecialChar | OtherKey;

regex Key;
