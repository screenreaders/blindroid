define InitialTranscription InitialLetterMapping+;

define Vowel 
a0|a1|e0|a1|i0|i1|ii0|ii1|o0|o1|u0|u1;

define VowelStress 
a0:a1|e0:e1|i0:i1|ii0:ii1|o0:o1|u0:u1;

